{
  "redirects": [
    {
      "source": "/about-us",
      "destination": "/the-lab.html",
      "permanent": true
    },
    {
      "source": "/about-us/",
      "destination": "/the-lab.html",
      "permanent": true
    },

    {
      "source": "/contact",
      "destination": "/cindex.html#booking-form",
      "permanent": true
    },
    {
      "source": "/contact/",
      "destination": "//cindex.html#booking-form",
      "permanent": true
    },

    {
      "source": "/services/:slug",
      "destination": "/the-elements.html",
      "permanent": true
    },
    {
      "source": "/services/:slug/",
      "destination": "/the-elements.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/experiences/:slug",
      "destination": "/show-details.html"
    }
  ]
}
